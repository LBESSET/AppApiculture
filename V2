
!DOCTYPE html>
<html>
<head>
  <title>App Apiculture</title>

  <style>
    body {
      margin: 0;
      font-family: Arial;
      display: flex;
    }

    /* Menu gauche */
    .menu {
      width: 200px;
      background-color: #2c3e50;
      color: white;
      height: 100vh;
      padding: 10px;
    }

    .menu div {
      margin: 10px 0;
      cursor: pointer;
    }

    .menu div:hover {
      background-color: #34495e;
      padding-left: 5px;
    }

    /* Contenu */
    .content {
      flex: 1;
      padding: 20px;
    }

    input, select, button {
      padding: 10px;
      margin: 5px;
    }

    .card {
      border: 1px solid #ccc;
      padding: 10px;
      margin: 10px;
    }

    .hidden {
      display: none;
    }
  </style>
</head>

<body>

<!-- MENU -->
<div class="menu">
  <h3>🐝 Menu</h3>
  <div onclick="showPage('rucher')">Rucher</div>
  <div onclick="showPage('ruche')">Ruche</div>
  <div onclick="showPage('reines')">Reines</div>
  <div onclick="showPage('param')">Paramètres</div>
</div>

<!-- CONTENU -->
<div class="content">

  <!-- PAGE RUCHER -->
  <div id="rucher">
    <h1>Ruchers</h1>

    <input type="text" id="nomRucher" placeholder="Nom du rucher">
    <input type="text" id="commune" placeholder="Commune">

    <br>
    <button onclick="ajouterRucher()">Ajouter rucher</button>

    <div id="listeRuchers"></div>
  </div>

  <!-- PAGE RUCHE -->
  <div id="ruche" class="hidden">
    <h1>Ruches</h1>

    <input type="text" id="nomRuche" placeholder="Nom de la ruche">

    <select id="selectRucher">
      <option value="">Choisir un rucher</option>
    </select>

    <br>
    <button onclick="ajouterRuche()">Ajouter ruche</button>

    <div id="listeRuches"></div>
  </div>

  <!-- PAGE REINES -->
  <div id="reines" class="hidden">
    <h1>Reines</h1>
    <p>À venir…</p>
  </div>

  <!-- PAGE PARAM -->
  <div id="param" class="hidden">
    <h1>Paramètres</h1>
    <p>À venir…</p>
  </div>

</div>

<script>

let ruchers = [];
let ruches = [];

/* Navigation */
function showPage(page) {
  document.getElementById("rucher").classList.add("hidden");
  document.getElementById("ruche").classList.add("hidden");
  document.getElementById("reines").classList.add("hidden");
  document.getElementById("param").classList.add("hidden");

  document.getElementById(page).classList.remove("hidden");
}

/* Ajouter rucher */
function ajouterRucher() {
  let nom = document.getElementById("nomRucher").value;
  let commune = document.getElementById("commune").value;

  if (!nom || !commune) {
    alert("Remplir tous les champs");
    return;
  }

  ruchers.push({ nom, commune });

  sauvegarder();
  afficherRuchers();
  remplirSelect();
}

/* Afficher ruchers */
function afficherRuchers() {
  let container = document.getElementById("listeRuchers");
  container.innerHTML = "";

  ruchers.forEach(r => {
    container.innerHTML += `
      <div class="card">
        <b>${r.nom}</b><br>
        Commune : ${r.commune}
      </div>
    `;
  });
}

/* Remplir liste déroulante */
function remplirSelect() {
  let select = document.getElementById("selectRucher");
  select.innerHTML = '<option value="">Choisir un rucher</option>';

  ruchers.forEach((r, index) => {
    select.innerHTML += `<option value="${index}">${r.nom}</option>`;
  });
}

/* Ajouter ruche */
function ajouterRuche() {
  let nom = document.getElementById("nomRuche").value;
  let index = document.getElementById("selectRucher").value;

  if (!nom || index === "") {
    alert("Remplir tous les champs");
    return;
  }

  ruches.push({ nom, rucher: ruchers[index].nom });

  sauvegarder();
  afficherRuches();
}

/* Afficher ruches */
function afficherRuches() {
  let container = document.getElementById("listeRuches");
  container.innerHTML = "";

  ruches.forEach(r => {
    container.innerHTML += `
      <div class="card">
        <b>${r.nom}</b><br>
        Rucher : ${r.rucher}
      </div>
    `;
  });
}

/* Sauvegarde */
function sauvegarder() {
  localStorage.setItem("ruchers", JSON.stringify(ruchers));
  localStorage.setItem("ruches", JSON.stringify(ruches));
}

/* Chargement */
function charger() {
  let dataRuchers = localStorage.getItem("ruchers");
  let dataRuches = localStorage.getItem("ruches");

  if (dataRuchers) {
    ruchers = JSON.parse(dataRuchers);
    afficherRuchers();
    remplirSelect();
  }

  if (dataRuches) {
    ruches = JSON.parse(dataRuches);
    afficherRuches();
  }
}

charger();

</script>

</body>
</html>
